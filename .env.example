# ── Frontend Analytics (Vite exposes VITE_* vars to the browser) ─────────────

# Google Analytics 4 — Measurement ID from analytics.google.com
# Format: G-XXXXXXXXXX
VITE_GA4_ID=G-XXXXXXXXXX

# Microsoft Clarity — Project ID from clarity.microsoft.com
# Format: 10-character alphanumeric string
VITE_CLARITY_ID=XXXXXXXXXX

# ── Backend ───────────────────────────────────────────────────────────────────

# Google OAuth2 Configuration
# Get these from Google Cloud Console: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your-client-id-here.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret-here

# MongoDB (optional - for Vercel deployment)
MONGODB_URI=your-mongodb-connection-string-here

# Resend — email sending (invoice PDF delivery)
# Get from: https://resend.com/api-keys
# Domain fakturidias.app must be verified in your Resend account
RESEND_API_KEY=re_...

# Vertex AI — Gemini (commercial, enterprise-grade)
# Setup:
#   1. Enable "Vertex AI API" at console.cloud.google.com/apis
#   2. Create a service account with role "Vertex AI User"
#   3. Download the JSON key and set the path below
VERTEX_PROJECT_ID=your-gcp-project-id
VERTEX_LOCATION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account-key.json
# Optional: override model (default: gemini-1.5-flash)
# GEMINI_MODEL=gemini-1.5-flash

# ── Stripe — billing / subscriptions ─────────────────────────────────────────
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...

# Webhook signing secret — from Stripe Dashboard > Webhooks
# Events to enable: checkout.session.completed, customer.subscription.updated, customer.subscription.deleted
STRIPE_WEBHOOK_SECRET=whsec_...

# Price IDs — create products/prices at https://dashboard.stripe.com/products
# Standard tier (65 CZK / month)
STRIPE_PRICE_MONTHLY=price_...
# Standard tier (650 CZK / year)
STRIPE_PRICE_ANNUAL=price_...
# Max tier (120 CZK / month)
STRIPE_PRICE_MAX_MONTHLY=price_...
# Max tier (1200 CZK / year)
STRIPE_PRICE_MAX_ANNUAL=price_...
